generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum Permission {
  RECRUITER_APPROVAL
  JOB_MODERATION
  CANDIDATE_MANAGEMENT
  SUB_ADMIN_MANAGEMENT
  REPORTS
}

model Candidate {
  id       String   @id @default(uuid())
  email    String   @unique
  fullName String
  mobile   String
  password String
  role     UserRole @default(CANDIDATE)

  // Added address fields for signup
  address String?
  city    String?
  state   String?
  pinCode String?

  isVerified         Boolean @default(false)
  isActive           Boolean @default(true)
  isProfileCompleted Boolean @default(false)

  profile       CandidateProfile?
  applications  Application[]
  savedJobs     SavedJob[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  password     String
  role         UserRole @default(ADMIN)
  isVerified   Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)

  permissions Permission[] // Optional permissions for sub-admins

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model CandidateProfile {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  // Personal Details (now mostly in Candidate, but keeping some here for detailed profile)
  dob    String?
  gender String?

  // Education
  qualification String?
  college       String?
  passingYear   String?

  // Experience
  isExperienced Boolean @default(false)
  companyName   String?
  department    String?
  yearsOfExp    String?

  // Skills
  skills   String?
  skillIds Skill[] @relation("CandidateSkills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Recruiter {
  id                 String             @id @default(uuid())
  email              String             @unique
  fullName           String
  companyName        String
  mobile             String
  password           String
  role               UserRole           @default(RECRUITER)
  verificationStatus VerificationStatus @default(PENDING)
  isActive           Boolean            @default(true)
  isProfileCompleted Boolean            @default(false)
  address            String?
  city               String?
  state              String?
  pinCode            String?

  profile       CompanyProfile?
  jobs          Job[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([verificationStatus])
}

model CompanyProfile {
  id          String    @id @default(uuid())
  recruiterId String    @unique
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id])

  companyName String?

  // Company Details
  industry  String?
  gstNumber String?
  website   String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  role      UserRole
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

model Job {
  id          String    @id @default(uuid())
  recruiterId String
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  title            String
  jobType          JobType?
  experience       String // e.g. "0-1 years", "2-3 years", "5+ years"
  salaryMin        Int?
  salaryMax        Int?
  location         String
  vacancies        Int      @default(1)
  description      String   @db.Text
  responsibilities String?  @db.Text
  requirements     String?  @db.Text
  skills           String?  @db.Text

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  skillsReq    Skill[]     @relation("JobSkills")

  benefits   String?   @db.Text
  deadline   DateTime?
  isFeatured Boolean   @default(false)
  isRemote   Boolean   @default(false)
  isFlagged  Boolean   @default(false)
  isRemoved  Boolean   @default(false)

  status       JobStatus     @default(OPEN)
  applications Application[]
  savedBy      SavedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recruiterId])
  @@index([status])
  @@index([location])
  @@index([departmentId])
  @@index([isFlagged])
  @@index([isRemoved])
  @@index([createdAt])
  @@index([title])
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  HIRED
  REJECTED
}

model Application {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  status ApplicationStatus @default(APPLIED)
  selectedSkills Skill[] @relation("ApplicationSkills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, candidateId]) // Prevent duplicate applications
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
}


model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id       String  @id @default(uuid())
  name     String  @unique
  category String? // e.g. "IT", "Non-IT", "Healthcare"

  jobs              Job[]              @relation("JobSkills")
  applications      Application[]      @relation("ApplicationSkills")
  candidateProfiles CandidateProfile[] @relation("CandidateSkills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String  @id @default(uuid())
  type    String // SUBSCRIPTION_EXPIRING | SUBSCRIPTION_EXPIRED
  message String
  isRead  Boolean @default(false)

  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  recruiterId String?
  recruiter   Recruiter? @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([candidateId])
  @@index([recruiterId])
}

model SavedJob {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([createdAt])
}